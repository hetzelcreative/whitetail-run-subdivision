---
import "../styles/global.css";
import { Image } from "astro:assets";
import about1 from "../assets/images/about-1.png";
import about2 from "../assets/images/about-2.jpg";
import mapImage from "../assets/images/map.png";
import heroImage from "../assets/images/hero.jpg";
import Section from "../components/Section.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Vollkorn:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700;1,800;1,900&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>Whitetail Run - Glenwood, Iowa</title>
  </head>
  <body class="font-sans antialiased">
    <!-- Header -->
    <header
      id="main-header"
      class="fixed top-0 left-0 right-0 z-50 py-6 transition-all duration-300"
    >
      <div class="container mx-auto px-6">
        <div class="flex items-center justify-between">
          <!-- Logo -->
          <div class="flex-shrink-0">
            <a href="#" id="logo-link" class="cursor-pointer">
              <img
                src="/whitetail-run-logo.png"
                alt="Whitetail Run"
                class="h-28 w-auto transition-all duration-300"
                id="header-logo"
              />
            </a>
          </div>

          <!-- Navigation -->
          <nav
            class="hidden md:flex items-center space-x-8"
            style="font-family: 'Inter', sans-serif;"
          >
            <a
              href="#about"
              class="nav-link text-stone-800 hover:text-stone-600 transition-colors font-bold text-sm uppercase tracking-widest"
              data-section="about">About</a
            >
            <a
              href="#location"
              class="nav-link text-stone-800 hover:text-stone-600 transition-colors font-bold text-sm uppercase tracking-widest"
              data-section="location">Location</a
            >
            <a
              href="#available-lots"
              class="nav-link text-stone-800 hover:text-stone-600 transition-colors font-bold text-sm uppercase tracking-widest"
              data-section="available-lots">Available Lots</a
            >
            <a
              href="#homes-for-sale"
              class="nav-link text-stone-800 hover:text-stone-600 transition-colors font-bold text-sm uppercase tracking-widest"
              data-section="homes-for-sale">Homes For Sale</a
            >
            <a
              href="#contact"
              class="nav-link text-stone-800 hover:text-stone-600 transition-colors font-bold text-sm uppercase tracking-widest"
              data-section="contact">Contact</a
            >
          </nav>

          <!-- CTA Button -->
          <div class="flex-shrink-0">
            <a
              href="#contact"
              class="bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-md font-medium transition-colors uppercase tracking-widest text-sm"
              style="font-family: 'Inter', sans-serif;"
            >
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Hero Section -->
    <section
      id="hero"
      class="relative min-h-screen flex flex-col bg-cover bg-center"
      style="background-image: url('/hero.jpg');"
    >
      <!-- Overlay -->
      <div class="absolute inset-0 bg-stone-50/75"></div>

      <!-- Hero Content -->
      <div
        class="relative z-10 flex-1 flex items-center justify-center text-center px-6 py-32 pt-48"
      >
        <div>
          <p class="text-stone-700 text-base tracking-widest uppercase mb-6">
            Glenwood, Iowa
          </p>

          <h1
            class="text-6xl md:text-8xl font-semibold text-stone-900 mb-8"
            style="font-family: 'Vollkorn', serif;"
          >
            Welcome to<br />
            <span class="italic">Whitetail Run</span>
          </h1>

          <p
            class="text-lg md:text-xl text-stone-700 max-w-3xl mx-auto mb-12 leading-relaxed"
          >
            Discover your dream homesite in this exclusive subdivision featuring
            spacious lots, mature oak trees, and the peaceful beauty of Iowa
            countryside.
          </p>

          <!-- CTA Buttons -->
          <div
            class="flex flex-col sm:flex-row items-center justify-center gap-4"
          >
            <a
              href="#available-lots"
              class="bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-md font-medium transition-colors uppercase tracking-widest text-sm"
              style="font-family: 'Inter', sans-serif;"
            >
              View Available Lots
            </a>
            <a
              href="#tour"
              class="bg-transparent border-2 border-stone-800 text-stone-800 hover:bg-stone-800 hover:text-white px-8 py-4 rounded-md font-medium transition-colors uppercase tracking-widest text-sm"
              style="font-family: 'Inter', sans-serif;"
            >
              Schedule a Tour
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <Section id="about" class="gradient-bg">
      <div class="grid md:grid-cols-2 gap-20 items-center">
        <!-- Left: Images -->
        <div class="relative">
          <!-- Background Image - Full Width -->
          <Image
            src={about1}
            alt="Whitetail Run neighborhood"
            class="w-full h-auto rounded-lg shadow-lg"
            widths={[600, 800, 1000]}
            sizes="(max-width: 768px) 100vw, 600px"
          />
          <!-- Overlay Image - Positioned Bottom Right -->
          <div
            class="absolute bottom-0 right-0 w-3/5 transform translate-y-8 translate-x-8"
          >
            <Image
              src={about2}
              alt="Whitetail Run oak trees"
              class="w-full h-auto rounded-lg shadow-2xl"
              widths={[400, 600, 800]}
              sizes="(max-width: 768px) 60vw, 400px"
            />
          </div>
        </div>

        <!-- Right: Content -->
        <div>
          <p
            class="text-red-600 text-sm font-bold tracking-widest uppercase mb-4"
            style="font-family: 'Inter', sans-serif;"
          >
            About Whitetail Run
          </p>

          <h2
            class="text-5xl md:text-6xl font-semibold text-stone-900 mb-6"
            style="font-family: 'Vollkorn', serif;"
          >
            Where Nature Meets<br />
            <span class="text-blue-900 italic">Modern Living</span>
          </h2>

          <div class="decorative-line mb-8"></div>

          <p class="text-stone-600 text-lg mb-6 leading-relaxed">
            Nestled in the heart of Glenwood, Iowa, Whitetail Run Subdivision
            offers an unparalleled opportunity to build your dream home
            surrounded by natural beauty and modern conveniences.
          </p>

          <p class="text-stone-600 text-lg mb-10 leading-relaxed">
            Our thoughtfully planned community features spacious lots shaded by
            majestic oak trees, providing the perfect backdrop for family life
            while remaining just minutes from schools, shopping, and major
            highways.
          </p>

          <!-- Features Grid -->
          <div class="grid grid-cols-2 gap-6">
            <div class="flex items-start space-x-3">
              <div class="w-2 h-2 bg-red-600 rounded-full mt-2.5 flex-shrink-0">
              </div>
              <div>
                <h3
                  class="font-semibold text-stone-900 mb-1"
                  style="font-family: 'Vollkorn', serif; font-size: 1.5rem;"
                >
                  Prime Location
                </h3>
                <p class="text-stone-600 text-sm">
                  Minutes from downtown Glenwood
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-3">
              <div class="w-2 h-2 bg-red-600 rounded-full mt-2.5 flex-shrink-0">
              </div>
              <div>
                <h3
                  class="font-semibold text-stone-900 mb-1"
                  style="font-family: 'Vollkorn', serif; font-size: 1.5rem;"
                >
                  Scenic Beauty
                </h3>
                <p class="text-stone-600 text-sm">
                  Mature oak trees throughout
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-3">
              <div class="w-2 h-2 bg-red-600 rounded-full mt-2.5 flex-shrink-0">
              </div>
              <div>
                <h3
                  class="font-semibold text-stone-900 mb-1"
                  style="font-family: 'Vollkorn', serif; font-size: 1.5rem;"
                >
                  Quality Schools
                </h3>
                <p class="text-stone-600 text-sm">
                  Excellent Glenwood schools nearby
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-3">
              <div class="w-2 h-2 bg-red-600 rounded-full mt-2.5 flex-shrink-0">
              </div>
              <div>
                <h3
                  class="font-semibold text-stone-900 mb-1"
                  style="font-family: 'Vollkorn', serif; font-size: 1.5rem;"
                >
                  Flexible Building
                </h3>
                <p class="text-stone-600 text-sm">Bring your own builder</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Section>

    <!-- Prime Home Sites Section -->
    <Section background="bg-white">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <h2
          class="text-5xl md:text-6xl font-semibold mb-6"
          style="font-family: 'Vollkorn', serif;"
        >
          Prime <span class="text-red-600">HOME</span> Sites –<br />
          <span class="text-red-600 italic">Choose Yours Today!</span>
        </h2>
      </div>

      <!-- Plat Map -->
      <div class="relative mb-16">
        <div class="bg-stone-100 rounded-lg overflow-hidden">
          <Image
            src={mapImage}
            alt="Whitetail Run Subdivision Plat Map"
            class="w-full h-auto"
            widths={[800, 1200, 1600]}
            sizes="(max-width: 768px) 100vw, 1200px"
          />
        </div>

        <!-- "Models Coming Soon" Badge -->
        <div
          class="absolute top-8 left-8 bg-red-600 text-white rounded-full w-32 h-32 flex items-center justify-center shadow-2xl transform -rotate-12"
        >
          <div class="text-center">
            <p
              class="text-xl font-semibold italic leading-tight"
              style="font-family: 'Vollkorn', serif;"
            >
              Models<br />Coming<br />Soon!
            </p>
          </div>
        </div>
      </div>

      <!-- Features List -->
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-x-12 gap-y-4">
          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-red-600 rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-stone-800 text-lg">
              Western Iowa Network - Fiber Optic Internet
            </p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-red-600 rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-stone-800 text-lg">City Water & City Sewer</p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-red-600 rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-stone-800 text-lg">
              Located 20 Minutes from Offutt Air Force Base
            </p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-red-600 rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-stone-800 text-lg">
              Located 20 Minutes from the Omaha Metro Area
            </p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-red-600 rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-stone-800 text-lg">
              Close Proximity to Our Thriving Town Square
            </p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-red-600 rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-stone-800 text-lg">
              Close Proximity to Our City Park & Trails
            </p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-red-600 rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-stone-800 text-lg">
              Close Proximity to the High School & Middle School, Short Commute
              to the Elementary Schools
            </p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-red-600 rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-stone-800 text-lg">
              Glenwood Community School District
            </p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-red-600 rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-stone-800 text-lg">No HOA Fees</p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-red-600 rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-stone-800 text-lg">
              Townhome & Single Family Home Sites
            </p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-red-600 rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-stone-800 text-lg">Ranch & 2 Story Homes</p>
          </div>
        </div>

        <!-- CTA Button -->
        <div class="mt-12 text-center">
          <a
            href="#contact"
            class="inline-block bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-md font-medium transition-colors uppercase tracking-widest text-sm"
            style="font-family: 'Inter', sans-serif;"
          >
            View Available Lots
          </a>
        </div>
      </div>
    </Section>

    <!-- Location Section -->
    <Section id="location" class="gradient-bg">
      <!-- Section Content -->
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <!-- Left: Content -->
        <div>
          <h2
            class="text-5xl md:text-6xl font-semibold text-stone-900 mb-6"
            style="font-family: 'Vollkorn', serif;"
          >
            On the Edge of<br />
            <span class="text-blue-900 italic">Downtown Glenwood</span>
          </h2>

          <div class="decorative-line mb-8"></div>

          <p class="text-stone-600 text-lg mb-12 leading-relaxed">
            Whitetail Run offers the best of both worlds – peaceful country
            living with convenient access to everything the Omaha metro area has
            to offer. Located in Glenwood, Iowa, you'll enjoy small-town charm
            while being just a short drive from big-city amenities.
          </p>

          <!-- Nearby Locations -->
          <div class="grid grid-cols-2 gap-4">
            <div
              class="flex items-start gap-3 bg-white p-4 rounded-lg shadow-sm border border-stone-200"
            >
              <svg
                class="w-6 h-6 text-red-600 flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-stone-900 mb-1">Downtown Glenwood</h4>
                <p class="text-stone-600 text-sm">5 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-white p-4 rounded-lg shadow-sm border border-stone-200"
            >
              <svg
                class="w-6 h-6 text-red-600 flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-stone-900 mb-1">Glenwood Schools</h4>
                <p class="text-stone-600 text-sm">7 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-white p-4 rounded-lg shadow-sm border border-stone-200"
            >
              <svg
                class="w-6 h-6 text-red-600 flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-stone-900 mb-1">
                  Lake Manawa State Park
                </h4>
                <p class="text-stone-600 text-sm">15 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-white p-4 rounded-lg shadow-sm border border-stone-200"
            >
              <svg
                class="w-6 h-6 text-red-600 flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-stone-900 mb-1">
                  Council Bluffs, IA
                </h4>
                <p class="text-stone-600 text-sm">20 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-white p-4 rounded-lg shadow-sm border border-stone-200"
            >
              <svg
                class="w-6 h-6 text-red-600 flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-stone-900 mb-1">Omaha Metro</h4>
                <p class="text-stone-600 text-sm">30 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-white p-4 rounded-lg shadow-sm border border-stone-200"
            >
              <svg
                class="w-6 h-6 text-red-600 flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-stone-900 mb-1">
                  Offutt Air Force Base
                </h4>
                <p class="text-stone-600 text-sm">25 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-white p-4 rounded-lg shadow-sm border border-stone-200"
            >
              <svg
                class="w-6 h-6 text-red-600 flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-stone-900 mb-1">Eppley Airfield</h4>
                <p class="text-stone-600 text-sm">35 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-white p-4 rounded-lg shadow-sm border border-stone-200"
            >
              <svg
                class="w-6 h-6 text-red-600 flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-stone-900 mb-1">I-29 Access</h4>
                <p class="text-stone-600 text-sm">10 minutes</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Map -->
        <div class="relative">
          <div class="rounded-lg overflow-hidden shadow-xl aspect-square">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d47759.68741632384!2d-95.76987!3d41.04632!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x87938e3be1f5b5e3%3A0x9f9a8f4b4f7c7c7c!2sGlenwood%2C%20IA%2051534!5e0!3m2!1sen!2sus!4v1234567890123"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>
      </div>
    </Section>

    <!-- Lot Listings Section -->
    <Section id="available-lots" class="gradient-bg-dark">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <p
          class="text-red-600 text-sm font-bold tracking-widest uppercase mb-6"
          style="font-family: 'Inter', sans-serif;"
        >
          Find Your Lot
        </p>
        <h2
          class="text-5xl md:text-6xl font-semibold text-white mb-6"
          style="font-family: 'Vollkorn', serif;"
        >
          Available Homesites
        </h2>
        <div class="decorative-line mx-auto mb-8"></div>
        <p class="text-stone-300 text-lg max-w-3xl mx-auto leading-relaxed">
          Choose from a variety of lot sizes to find the perfect foundation for
          your dream home. Each lot offers unique features and positioning.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-start">
        <!-- Left: Plat Map -->
        <div class="rounded-lg overflow-hidden">
          <Image
            src={mapImage}
            alt="Whitetail Run Plat Map"
            class="w-full h-auto"
            widths={[600, 800]}
            sizes="(max-width: 768px) 100vw, 600px"
          />
        </div>

        <!-- Right: Lot Cards Grid -->
        <div class="grid grid-cols-3 gap-4">
          <!-- Lot 1 -->
          <div class="bg-stone-100 rounded-lg p-4">
            <div class="flex items-center justify-between mb-3">
              <h3
                class="text-lg font-semibold text-stone-900"
                style="font-family: 'Vollkorn', serif;"
              >
                Lot 1
              </h3>
              <span
                class="bg-green-600 text-white text-xs font-semibold px-3 py-1 rounded-full"
                >Available</span
              >
            </div>
            <div class="space-y-2">
              <p class="text-sm text-stone-600 flex items-center gap-1">
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                  ></path>
                </svg>
                0.52 acres
              </p>
            </div>
