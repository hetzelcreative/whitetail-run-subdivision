---
import "../styles/global.css";
import { Image } from "astro:assets";
import about1 from "../assets/images/about-1.png";
import about2 from "../assets/images/about-2.jpg";
import mapImage from "../assets/images/plot-map.png";
import heroImage from "../assets/images/hero.jpg";
import Section from "../components/Section.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Vollkorn:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700;1,800;1,900&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>Whitetail Run - Glenwood, Iowa</title>
  </head>
  <body class="font-sans antialiased">
    <!-- Header -->
    <header
      id="main-header"
      class="fixed top-0 left-0 right-0 z-50 py-2 transition-all duration-300 ease-in-out"
    >
      <div class="container mx-auto px-6">
        <div class="flex items-center justify-between">
          <!-- Logo -->
          <div class="flex-shrink-0 relative">
            <a href="#" id="logo-link" class="cursor-pointer">
              <img
                src="/whitetail-run-logo.png"
                alt="Whitetail Run"
                class="h-48 w-auto transition-all duration-300 ease-in-out"
                id="header-logo-full"
              />
              <img
                src="/whitetail-run-lettermark-white.png"
                alt="Whitetail Run"
                class="absolute top-0 left-0 transition-all duration-300 ease-in-out opacity-0"
                id="header-logo-mark"
                style="width: 190px; height: auto; max-width: none;"
              />
            </a>
          </div>

          <!-- Navigation -->
          <nav
            class="hidden md:flex items-center space-x-8"
            style="font-family: 'Inter', sans-serif;"
          >
            <a
              href="#about"
              class="nav-link text-slate-200 hover:text-gold transition-colors font-bold text-sm uppercase tracking-widest"
              data-section="about">About</a
            >
            <a
              href="#location"
              class="nav-link text-slate-200 hover:text-gold transition-colors font-bold text-sm uppercase tracking-widest"
              data-section="location">Location</a
            >
            <a
              href="#acreages-for-sale"
              class="nav-link text-slate-200 hover:text-gold transition-colors font-bold text-sm uppercase tracking-widest"
              data-section="acreages-for-sale">Acreages For Sale</a
            >
            <a
              href="#contact"
              class="nav-link text-slate-200 hover:text-gold transition-colors font-bold text-sm uppercase tracking-widest"
              data-section="contact">Contact</a
            >
          </nav>

          <!-- CTA Button -->
          <div class="flex-shrink-0">
            <a
              href="#contact"
              class="text-white px-6 py-3 rounded-md font-medium transition-all uppercase tracking-widest text-sm shadow-lg hover:brightness-110"
              style="font-family: 'Inter', sans-serif; background: linear-gradient(to bottom, #2C5046, #313D3D);"
            >
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Hero Section -->
    <section
      id="hero"
      class="relative min-h-screen flex flex-col overflow-hidden"
    >
      <!-- Video Background -->
      <video
        autoplay
        loop
        muted
        playsinline
        class="absolute inset-0 w-full h-full object-cover"
      >
        <source src="/hero-video.mp4" type="video/mp4" />
      </video>

      <!-- Overlay -->
      <div class="absolute inset-0 bg-gradient-to-b from-emerald-950/85 via-slate-900/80 to-emerald-950/90" style="background: linear-gradient(to bottom, rgba(46, 53, 54, 0.85), rgba(47, 58, 58, 0.8), rgba(46, 53, 54, 0.9));"></div>

      <!-- Hero Content -->
      <div
        class="relative z-10 flex-1 flex items-center justify-center text-center px-6 py-32 pt-48"
        style="padding-top: calc(12rem + 60px);"
      >
        <div>
          <p class="text-gold text-base tracking-widest uppercase mb-6 font-semibold">
            Glenwood, IA Subdivision
          </p>

          <h1
            class="text-6xl md:text-8xl font-semibold mb-8 text-white"
            style="font-family: 'Vollkorn', serif;"
          >
            Where Nature<br />
            Meets Home
          </h1>

          <p
            class="text-lg md:text-xl text-slate-200 max-w-3xl mx-auto mb-12 leading-relaxed"
          >
            Discover your dream homesite in this exclusive subdivision featuring
            spacious lots, mature trees, and the peaceful beauty of Iowa
            countryside.
          </p>

          <!-- CTA Buttons -->
          <div
            class="flex flex-col sm:flex-row items-center justify-center gap-4"
          >
            <a
              href="#tour"
              class="bg-transparent border-2 text-gold hover:bg-gold hover:text-green-900 px-8 py-4 rounded-md font-medium transition-all uppercase tracking-widest text-sm hover:shadow-lg"
              style="font-family: 'Inter', sans-serif; border-color: #C99255;"
            >
              View Acreages For Sale
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <Section id="about" class="gradient-bg">
      <div class="grid md:grid-cols-2 gap-20 items-center">
        <!-- Left: Video -->
        <div class="relative">
          <video
            controls
            class="w-full h-auto rounded-lg shadow-lg"
            poster="/video-poster.jpg"
          >
            <source src="/hero-video.mp4" type="video/mp4" />
            Your browser does not support the video tag.
          </video>
        </div>

        <!-- Right: Content -->
        <div>
          <p
            class="text-gold text-sm font-bold tracking-widest uppercase mb-4"
            style="font-family: 'Inter', sans-serif;"
          >
            About Whitetail Run
          </p>

          <h2
            class="text-5xl md:text-6xl font-semibold mb-6 text-white"
            style="font-family: 'Vollkorn', serif;"
          >
            Live the Acreage Life<br />
            <span class="text-gold italic">Close to Glenwood</span>
          </h2>

          <div class="decorative-line mb-8"></div>

          <p class="text-slate-300 text-lg mb-6 leading-relaxed">
            Whitetail Run gives you what's hard to find anymore: real acreage, real privacy, and a real community just down the road. With homesites starting at one acre just outside Glenwood, you get the space to build your way without leaving the convenience of town far behind.
          </p>

          <p class="text-slate-300 text-lg mb-10 leading-relaxed">
            Big lots, open sky, and room to build exactly what you want. Council Bluffs and the Omaha metro are just minutes up I-29, while the Loess Hills, scenic views, and western Iowa wildlife are right outside your door.
          </p>

          <!-- Features Grid -->
          <div class="grid grid-cols-2 gap-6">
            <div class="flex items-start space-x-3">
              <div class="w-2 h-2 bg-gold rounded-full mt-2.5 flex-shrink-0">
              </div>
              <div>
                <h3
                  class="font-semibold text-white mb-1"
                  style="font-family: 'Vollkorn', serif; font-size: 1.5rem;"
                >
                  Prime Location
                </h3>
                <p class="text-slate-300 text-sm">
                  Minutes from Glenwood, I-29, and the Omaha Metro
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-3">
              <div class="w-2 h-2 bg-gold rounded-full mt-2.5 flex-shrink-0">
              </div>
              <div>
                <h3
                  class="font-semibold text-white mb-1"
                  style="font-family: 'Vollkorn', serif; font-size: 1.5rem;"
                >
                  Scenic Wildlife Setting
                </h3>
                <p class="text-slate-300 text-sm">
                  Mature trees and wildlife views on every lot
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-3">
              <div class="w-2 h-2 bg-gold rounded-full mt-2.5 flex-shrink-0">
              </div>
              <div>
                <h3
                  class="font-semibold text-white mb-1"
                  style="font-family: 'Vollkorn', serif; font-size: 1.5rem;"
                >
                  Quality Schools
                </h3>
                <p class="text-slate-300 text-sm">
                  Excellent Glenwood schools nearby
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-3">
              <div class="w-2 h-2 bg-gold rounded-full mt-2.5 flex-shrink-0">
              </div>
              <div>
                <h3
                  class="font-semibold text-white mb-1"
                  style="font-family: 'Vollkorn', serif; font-size: 1.5rem;"
                >
                  Paved Roads
                </h3>
                <p class="text-slate-300 text-sm">No gravel travel - all roads are paved!</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Section>

    <!-- Prime Home Sites Section -->
    <Section background="bg-forest">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <h2
          class="text-5xl md:text-6xl font-semibold mb-6 text-white"
          style="font-family: 'Vollkorn', serif;"
        >
          Your Acreage Awaits<br />
          <span class="text-gold italic">Start Building Yours Today!</span>
        </h2>
      </div>

      <!-- Plat Map -->
      <div class="relative mb-16">
        <div class="bg-slate-800/50 backdrop-blur-sm rounded-lg overflow-hidden">
          <Image
            src={mapImage}
            alt="Whitetail Run Subdivision Plat Map"
            class="w-full h-auto"
            widths={[800, 1200, 1600]}
            sizes="(max-width: 768px) 100vw, 1200px"
          />
        </div>

        <!-- "Models Coming Soon" Badge -->
        <div
          class="absolute top-8 left-8 bg-gold text-white rounded-full w-32 h-32 flex items-center justify-center shadow-2xl transform -rotate-12"
        >
          <div class="text-center">
            <p
              class="text-xl font-semibold italic leading-tight"
              style="font-family: 'Vollkorn', serif;"
            >
              Models<br />Coming<br />Soon!
            </p>
          </div>
        </div>
      </div>

      <!-- Features List -->
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-x-12 gap-y-4">
          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-gold rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-slate-100 text-lg">
              20 Minutes to Omaha & Council Bluffs
            </p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-gold rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-slate-100 text-lg">One-Acre-Plus Homesites</p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-gold rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-slate-100 text-lg">
              Paved Roads
            </p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-gold rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-slate-100 text-lg">
              Private Timber-Lined Homesites
            </p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-gold rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-slate-100 text-lg">
              Scenic Views & Wildlife
            </p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-gold rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-slate-100 text-lg">
              All Single-Family Homes
            </p>
          </div>

          <div class="flex items-start space-x-3">
            <div class="w-2 h-2 bg-gold rounded-full mt-2 flex-shrink-0">
            </div>
            <p class="text-slate-100 text-lg">
              Glenwood Community School District
            </p>
          </div>
        </div>

        <!-- CTA Button -->
        <div class="mt-12 text-center">
          <a
            href="#contact"
            class="inline-block hover:brightness-110 text-white px-8 py-4 rounded-md font-medium transition-colors uppercase tracking-widest text-sm"
            style="font-family: 'Inter', sans-serif; background: linear-gradient(to bottom, #2C5046, #313D3D);"
          >
            Contact Us
          </a>
        </div>
      </div>
    </Section>

    <!-- Location Section -->
    <Section id="location" class="gradient-bg">
      <!-- Section Content -->
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <!-- Left: Content -->
        <div>
          <h2
            class="text-5xl md:text-6xl font-semibold mb-6 text-white"
            style="font-family: 'Vollkorn', serif;"
          >
            Close to Omaha<br />
            <span class="text-gold italic">Far From The Noise</span>
          </h2>

          <div class="decorative-line mb-8"></div>

          <p class="text-slate-300 text-lg mb-12 leading-relaxed">
            Living on an acreage doesn't mean living far from everything. Whitetail Run keeps you connected to Glenwood, Council Bluffs, and the Omaha metro while giving you the peace and privacy that only country living provides.
          </p>

          <!-- Nearby Locations -->
          <div class="grid grid-cols-2 gap-4">
            <div
              class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
            >
              <svg
                class="w-6 h-6 text-gold flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-white mb-1">Downtown Glenwood</h4>
                <p class="text-slate-300 text-sm">8 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
            >
              <svg
                class="w-6 h-6 text-gold flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-white mb-1">Glenwood Schools</h4>
                <p class="text-slate-300 text-sm">8 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
            >
              <svg
                class="w-6 h-6 text-gold flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-white mb-1">
                  Lake Manawa State Park
                </h4>
                <p class="text-slate-300 text-sm">22 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
            >
              <svg
                class="w-6 h-6 text-gold flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-white mb-1">
                  Council Bluffs, IA
                </h4>
                <p class="text-slate-300 text-sm">20 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
            >
              <svg
                class="w-6 h-6 text-gold flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-white mb-1">Omaha</h4>
                <p class="text-slate-300 text-sm">25 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
            >
              <svg
                class="w-6 h-6 text-gold flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-white mb-1">
                  Offutt Air Force Base
                </h4>
                <p class="text-slate-300 text-sm">25 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
            >
              <svg
                class="w-6 h-6 text-gold flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-white mb-1">Eppley Airfield</h4>
                <p class="text-slate-300 text-sm">34 minutes</p>
              </div>
            </div>

            <div
              class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
            >
              <svg
                class="w-6 h-6 text-gold flex-shrink-0 mt-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <h4 class="font-bold text-white mb-1">I-29 Access</h4>
                <p class="text-slate-300 text-sm">12 minutes</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Map -->
        <div class="relative">
          <div class="rounded-lg overflow-hidden shadow-xl aspect-square">
            <iframe
              src="https://maps.google.com/maps?q=23106+Frontier+Lane,+Glenwood,+IA+51534&t=&z=14&ie=UTF8&iwloc=&output=embed"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>
      </div>
    </Section>

    <!-- Acreages for Sale Section -->
    <Section id="acreages-for-sale" background="bg-forest">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <p
          class="text-gold text-sm font-bold tracking-widest uppercase mb-6"
          style="font-family: 'Inter', sans-serif;"
        >
          Current Listings
        </p>
        <h2
          class="text-5xl md:text-6xl font-semibold text-white mb-6"
          style="font-family: 'Vollkorn', serif;"
        >
          Acreages for Sale
        </h2>
        <div class="decorative-line mx-auto mb-8"></div>
        <p class="text-slate-300 text-lg max-w-3xl mx-auto leading-relaxed">
          Discover move-in ready homes built by quality local builders, or
          purchase a lot to build your custom dream home.
        </p>
      </div>

      <!-- Property Cards -->
      <div class="grid md:grid-cols-3 gap-8 max-w-7xl mx-auto">
        <!-- Property 1 -->
        <div class="bg-slate-800/60 rounded-xl overflow-hidden shadow-xl shadow-amber-900/20 border border-slate-700/30">
          <div class="relative">
            <Image
              src={heroImage}
              alt="Modern Farmhouse on Lot 7"
              class="w-full h-64 object-cover"
              widths={[400, 600]}
              sizes="(max-width: 768px) 100vw, 400px"
            />
            <span
              class="absolute top-4 left-4 bg-green-600 text-white text-sm font-semibold px-4 py-2 rounded-full"
              >For Sale</span
            >
            <div
              class="absolute top-4 right-4 bg-white text-white text-2xl font-semibold px-4 py-2 rounded-lg"
              style="font-family: 'Vollkorn', serif;"
            >
              $485,000
            </div>
          </div>
          <div class="p-6">
            <h3
              class="text-2xl font-semibold text-white mb-4"
              style="font-family: 'Vollkorn', serif;"
            >
              Modern Farmhouse on Lot 7
            </h3>
            <div class="flex items-center gap-6 text-slate-300 mb-6">
              <div class="flex items-center gap-2">
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                  ></path>
                </svg>
                <span>4 Beds</span>
              </div>
              <div class="flex items-center gap-2">
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                  ></path>
                </svg>
                <span>3 Baths</span>
              </div>
              <div class="flex items-center gap-2">
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
