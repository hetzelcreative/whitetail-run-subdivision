---
import Button from "./ui/Button.astro";
import Section from "./Section.astro";
---

<Section id="contact" class="gradient-bg">
  <div class="grid md:grid-cols-2 gap-16 items-start">
    <!-- Left: Contact Info -->
    <div>
      <p class="font-body text-gold text-sm font-bold tracking-widest uppercase mb-6">
        Get in Touch
      </p>

      <h2 class="font-heading text-5xl md:text-6xl font-semibold text-white mb-6">
        Ready to Find Your<br />
        <span class="italic">Perfect Homesite?</span>
      </h2>

      <div class="w-16 h-1 bg-gold mb-8"></div>

      <p class="text-stone-300 text-lg mb-12 leading-relaxed">
        Whether you're looking to purchase a lot, explore available
        properties, or just want to learn more about Whitetail Run, we're
        here to help. Reach out today and let us guide you home.
      </p>

      <!-- Contact Details -->
      <div class="space-y-8 mb-12">
        <!-- Phone -->
        <div class="flex items-start gap-4">
          <div
            class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0"
          >
            <svg
              class="w-6 h-6 text-gold"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
          </div>
          <div>
            <p class="text-white/70 text-sm mb-1">Call Us</p>
            <a
              href="tel:+17125273114"
              class="text-white text-2xl font-bold hover:text-gold transition-colors"
              >(712) 527-3114</a
            >
          </div>
        </div>

        <!-- Email -->
        <div class="flex items-start gap-4">
          <div
            class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0"
          >
            <svg
              class="w-6 h-6 text-gold"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <div>
            <p class="text-white/70 text-sm mb-1">Email Us</p>
            <a
              href="mailto:info@jimhughesrealestate.com"
              class="text-white text-xl font-bold hover:text-gold transition-colors"
              >info@jimhughesrealestate.com</a
            >
          </div>
        </div>

        <!-- Location -->
        <div class="flex items-start gap-4">
          <div
            class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0"
          >
            <svg
              class="w-6 h-6 text-gold"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <div>
            <p class="text-white/70 text-sm mb-1">Visit Us</p>
            <p class="text-white text-xl font-bold">23106 Frontier Ln, Glenwood, IA 51534</p>
          </div>
        </div>
      </div>

      <!-- Listed By Box -->
      <div
        class="border-2 border-stone-700 rounded-lg p-6 flex items-center gap-6 bg-stone-800"
      >
        <img
          src="/jhre-logo.svg"
          alt="Jim Hughes Real Estate"
          class="h-24 w-auto flex-shrink-0"
        />
        <div>
          <p class="text-white/70 text-sm mb-2">Listed by</p>
          <h3 class="font-heading text-gold text-3xl font-bold mb-2">
            <a href="https://www.jimhughesrealestate.com" target="_blank" rel="noopener noreferrer" class="hover:brightness-125 transition-all">Jim Hughes Real Estate</a>
          </h3>
          <p class="text-stone-300">410 South Locust, Glenwood, IA 51534</p>
        </div>
      </div>
    </div>

    <!-- Right: Contact Form -->
    <div class="bg-slate-800/40 rounded-lg p-8 border border-slate-700/50 shadow-lg shadow-amber-900/10">
      <h3 class="font-heading text-3xl font-semibold text-white mb-8">
        Send Us a Message
      </h3>

      <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="space-y-6">
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <!-- Name and Phone Row -->
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <input
              type="text"
              name="name"
              placeholder="John Smith"
              required
              class="w-full px-4 py-3 bg-slate-900/50 border-2 border-slate-600/50 rounded-lg focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 transition-colors text-white"
            />
          </div>
          <div>
            <input
              type="tel"
              name="phone"
              placeholder="(402) 555-1234"
              class="w-full px-4 py-3 bg-slate-900/50 border-2 border-slate-600/50 rounded-lg focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 transition-colors text-white"
            />
          </div>
        </div>

        <!-- Email -->
        <div>
          <input
            type="email"
            name="email"
            placeholder="john@example.com"
            required
            class="w-full px-4 py-3 bg-slate-900/50 border-2 border-slate-600/50 rounded-lg focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 transition-colors text-white"
          />
        </div>

        <!-- Select Dropdown -->
        <div>
          <select
            name="interest"
            required
            class="w-full px-4 py-3 bg-slate-900/50 border-2 border-slate-600/50 rounded-lg focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 transition-colors text-slate-300 appearance-none select-arrow"
          >
            <option value="">Select an option...</option>
            <option value="buying-lot">Interested in buying a lot</option>
            <option value="available-homes">Interested in available homes</option>
            <option value="general-inquiry">General inquiry</option>
            <option value="schedule-tour">Schedule a tour</option>
          </select>
        </div>

        <!-- Message Textarea -->
        <div>
          <textarea
            name="message"
            rows="6"
            placeholder="Tell us about what you're looking for..."
            required
            class="w-full px-4 py-3 bg-slate-900/50 border-2 border-slate-600/50 rounded-lg focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 transition-colors text-white resize-none"
          ></textarea>
        </div>

        <!-- Submit Button -->
        <Button type="submit" class="w-full px-8 py-4 flex items-center justify-center gap-2">
          Send Message
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
          </svg>
        </Button>
      </form>
    </div>
  </div>
</Section>
