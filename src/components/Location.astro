---
import Section from "./Section.astro";
---

<Section id="location" class="gradient-bg">
  <!-- Section Content -->
  <div class="grid md:grid-cols-2 gap-16 items-center">
    <!-- Left: Content -->
    <div>
      <h2 class="font-heading text-5xl md:text-6xl font-semibold mb-6 text-white">
        Close to Omaha<br />
        <span class="text-gold italic">Far From The Noise</span>
      </h2>

      <div class="decorative-line mb-8"></div>

      <p class="text-slate-300 text-lg mb-12 leading-relaxed">
        Living on an acreage doesn't mean living far from everything. Whitetail Run keeps you connected to Glenwood, Council Bluffs, and the Omaha metro while giving you the peace and privacy that only country living provides.
      </p>

      <!-- Nearby Locations -->
      <div class="grid grid-cols-2 gap-4">
        <div
          class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
        >
          <svg
            class="w-6 h-6 text-gold flex-shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-bold text-white mb-1">Downtown Glenwood</h4>
            <p class="text-slate-300 text-sm">8 minutes</p>
          </div>
        </div>

        <div
          class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
        >
          <svg
            class="w-6 h-6 text-gold flex-shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-bold text-white mb-1">Glenwood Schools</h4>
            <p class="text-slate-300 text-sm">8 minutes</p>
          </div>
        </div>

        <div
          class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
        >
          <svg
            class="w-6 h-6 text-gold flex-shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-bold text-white mb-1">
              Lake Manawa State Park
            </h4>
            <p class="text-slate-300 text-sm">22 minutes</p>
          </div>
        </div>

        <div
          class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
        >
          <svg
            class="w-6 h-6 text-gold flex-shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-bold text-white mb-1">
              Council Bluffs, IA
            </h4>
            <p class="text-slate-300 text-sm">20 minutes</p>
          </div>
        </div>

        <div
          class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
        >
          <svg
            class="w-6 h-6 text-gold flex-shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-bold text-white mb-1">Omaha</h4>
            <p class="text-slate-300 text-sm">25 minutes</p>
          </div>
        </div>

        <div
          class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
        >
          <svg
            class="w-6 h-6 text-gold flex-shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-bold text-white mb-1">
              Offutt Air Force Base
            </h4>
            <p class="text-slate-300 text-sm">25 minutes</p>
          </div>
        </div>

        <div
          class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
        >
          <svg
            class="w-6 h-6 text-gold flex-shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-bold text-white mb-1">Eppley Airfield</h4>
            <p class="text-slate-300 text-sm">34 minutes</p>
          </div>
        </div>

        <div
          class="flex items-start gap-3 bg-slate-800/40 p-4 rounded-lg shadow-lg shadow-amber-900/10 border border-slate-700/50"
        >
          <svg
            class="w-6 h-6 text-gold flex-shrink-0 mt-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="font-bold text-white mb-1">I-29 Access</h4>
            <p class="text-slate-300 text-sm">12 minutes</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Map -->
    <div class="relative">
      <div class="rounded-lg overflow-hidden shadow-xl aspect-square">
        <iframe
          src="https://maps.google.com/maps?q=23106+Frontier+Lane,+Glenwood,+IA+51534&t=&z=14&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="100%"
          class="border-0"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </div>
</Section>
